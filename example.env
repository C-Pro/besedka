# Chat name and database file path
CHAT_NAME=Besedka
BESEDKA_DB=besedka.db

# Admin API Address
ADMIN_ADDR=localhost:8081

# Main API Address
API_ADDR=:8080

# Base URL for the service (used for links)
BASE_URL=http://localhost:8080

# Secret key for JWT signing (REQUIRED)
# For development, you can use: very-secure-secret-key-for-development-mode
AUTH_SECRET=very-secure-secret-key-for-development-mode

# Directory to store uploaded files
UPLOADS_PATH=uploads

# --- Object storage (S3-compatible) backup & mirroring (optional) ---
# Leave S3_BUCKET / S3_ENDPOINT empty to disable entirely (default behavior).
# When enabled, Besedka mirrors every uploaded file to the bucket, backs up the
# database daily, recovers a missing database from the newest backup on startup,
# and fetches files from the bucket when they are missing locally.
# NOTE: object storage requires AUTH_SECRET to be set — backups and mirrored
# files are encrypted at rest using it. Startup fails if it is missing.
# S3_ENDPOINT=http://localhost:9000
# S3_REGION=us-east-1
# S3_BUCKET=besedka
# S3_ACCESS_KEY=minioadmin
# S3_SECRET_KEY=minioadmin
# S3_PATH_STYLE=true            # true for MinIO/self-hosted; false for AWS virtual-host
# S3_BACKUP_INTERVAL=24h
# S3_BACKUP_KEEP=7
